{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksJson": {
      "engines": {
        "node": "20"
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/",
    "healthcheckPort": 3000,
    "startCommand": "if [ \"$RUN_SEED\" = \"true\" ]; then npx ts-node src/database/seeds/index.ts; else npm start; fi"
  }
}
