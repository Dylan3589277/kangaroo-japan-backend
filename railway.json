{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksJson": {
      "engines": {
        "node": "20"
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/",
    "healthcheckPort": 3000,
    "environment": [
      {
        "name": "DATABASE_SYNC",
        "value": "true"
      }
    ]
  }
}
