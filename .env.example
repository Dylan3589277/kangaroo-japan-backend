# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=kangaroo
DATABASE_PASSWORD=kangaroo_dev_password
DATABASE_NAME=kangaroo_japan
# WARNING: NEVER set DATABASE_SYNC=true in production — TypeORM will auto-alter/drop tables and cause DATA LOSS.
# Use migrations (DATABASE_MIGRATIONS_RUN=true) for production schema changes.
DATABASE_SYNC=false
DATABASE_MIGRATIONS_RUN=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_password

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# App
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001

# Third-party APIs (to be filled)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PINGXX_SECRET_KEY=
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
EXCHANGE_RATE_API_KEY=
