# E2E Test Environment
# Overrides .env values when running E2E tests

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=kangaroo
DATABASE_PASSWORD=kangaroo_dev_password
DATABASE_NAME=kangaroo_dev
DATABASE_SYNC=true
DATABASE_MIGRATIONS_RUN=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=test-e2e-jwt-secret-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=test-e2e-jwt-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d

# App
PORT=0
NODE_ENV=test

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001

# Third-party APIs - use dummy values for testing
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_PUBLIC_KEY=pk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_dummy
PINGXX_API_KEY=pingxx_dummy
PINGXX_APP_ID=app_dummy
PINGXX_WEBHOOK_KEY=webhook_dummy

# Integration APIs - dummy values
RAKUTEN_APP_ID=test-app-id
RAKUTEN_ACCESS_KEY=test-access-key
RAKUTEN_AFFILIATE_ID=test-affiliate-id
AWS_ACCESS_KEY_ID=test-aws-key
AWS_SECRET_ACCESS_KEY=test-aws-secret
AMAZON_PARTNER_TAG=test-partner-tag
YAHOO_CLIENT_ID=test-yahoo-client-id
YAHOO_CLIENT_SECRET=test-yahoo-client-secret
MERCARI_SHOPS_TOKEN=test-mercari-token
ALGOLIA_API_KEY=test-algolia-key
EXCHANGE_RATE_API_KEY=test-exchange-key
